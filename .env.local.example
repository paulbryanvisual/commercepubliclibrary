# Commerce Public Library — Environment Variables
# Copy this file to .env.local and fill in your values

# ── Anthropic (Claude AI) ──
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Admin Auth ──
ADMIN_PASSWORD=your-admin-password-here
SESSION_SECRET=generate-a-random-32-char-string-here

# ── Sanity CMS (Phase 2+) ──
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_TOKEN=

# ── Atriuum ILS (Phase 4) ──
# ATRIUUM_SIP2_HOST=
# ATRIUUM_SIP2_PORT=6001
# ATRIUUM_SIP2_USER=
# ATRIUUM_SIP2_PASSWORD=
# ATRIUUM_Z3950_HOST=
# ATRIUUM_Z3950_PORT=210
# ATRIUUM_Z3950_DB=

# ── Tawk.to Live Chat ──
# TAWKTO_SITE_ID=
# TAWKTO_API_KEY=

# ── Givebutter (Donations/Newsletter) ──
# GIVEBUTTER_API_KEY=

# ── Resend (Transactional Email) ──
# RESEND_API_KEY=

# ── Algolia (Site Search) ──
# ALGOLIA_APP_ID=
# ALGOLIA_SEARCH_KEY=
# ALGOLIA_ADMIN_KEY=
